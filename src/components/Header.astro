---

<header class="nav-bar" role="banner">
  <a href="/" class="logo" aria-label="Residencia Los Molles — Inicio">LOS MOLLES</a>

  <nav aria-label="Navegación principal">
    <ul class="nav-links">
      <li><a href="#comodidades">Comodidades</a></li>
      <li><a href="#espacios">Espacios</a></li>
      <li><a href="#ubicacion">Ubicación</a></li>
      <li><a href="#faq">FAQ</a></li>
    </ul>
  </nav>

  <div class="right">
    <a
      class="cta-nav"
      href="https://api.whatsapp.com/send?phone=59177935606&text=Hola,%20quisiera%20solicitar%20una%20plaza%20en%20la%20residencia."
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Solicitar plaza por WhatsApp"
    >
      Solicitar Plaza
    </a>
    <button
      class="hamburger"
      id="hamburger"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <nav>
    <a href="#comodidades">Comodidades</a>
    <a href="#espacios">Espacios</a>
    <a href="#ubicacion">Ubicación</a>
    <a href="#faq">FAQ</a>
    <a
      class="cta-mobile"
      href="https://api.whatsapp.com/send?phone=59177935606&text=Hola,%20quisiera%20solicitar%20una%20plaza%20en%20la%20residencia."
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Solicitar plaza por WhatsApp"
    >
      Solicitar Plaza →
    </a>
  </nav>
</div>

<style>
  .nav-bar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 clamp(20px, 4vw, 48px);
    height: 64px;
    background: rgba(12, 22, 17, 0.65);
    backdrop-filter: blur(28px) saturate(160%);
    -webkit-backdrop-filter: blur(28px) saturate(160%);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .logo {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: 13px;
    color: white;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    font-family: 'Hind Madurai', sans-serif;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.03em;
    text-decoration: none;
    color: transparent;
    background: linear-gradient(to right, #ffffff 50%, rgba(255, 255, 255, 0.60) 50%);
    background-size: 200% 100%;
    background-position: 100% 0;
    -webkit-background-clip: text;
    background-clip: text;
    transition: background-position 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-links a:hover { 
    background-position: 0 0; 
  }

  .right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .cta-nav {
    font-family: 'Hind Madurai', sans-serif;
    font-weight: 900;
    font-size: 13px;
    letter-spacing: 0.04em;
    padding: 8px 20px;
    background: #ffffff;
    color: #000;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.2s, transform 0.15s;
  }

  .cta-nav:hover {
    background: transparent;
    color: #fff;
    border-color: #fff;
    border-width: 0.5px;
    border-style: solid;
    transform: translateY(-1px);
  }

  .cta-nav:active {
    background: transparent;
    color: #fff;
    border-color: #fff;
    border-width: 0.5px;
    border-style: solid;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    width: 32px;
    height: 32px;
  }

  .hamburger span {
    display: block;
    height: 1.5px;
    background: white;
    border-radius: 2px;
    transition: transform 0.35s ease, opacity 0.35s ease;
    transform-origin: center;
  }

  .hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  .mobile-menu {
    position: fixed;
    top: 64px;
    left: 0; right: 0;
    z-index: 199;
    background: rgba(5, 9, 7, 0.76);
    backdrop-filter: blur(32px);
    -webkit-backdrop-filter: blur(32px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-menu.open { max-height: 420px; }

  .mobile-menu nav {
    display: flex;
    flex-direction: column;
    padding: 12px 24px 28px;
    gap: 2px;
  }

  .mobile-menu a {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: rgba(255,255,255,0.72);
    text-decoration: none;
    padding: 14px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: color 0.2s;
  }

  .mobile-menu a:hover { color: #698F3F; }

  .cta-mobile {
    background-color: rgba(0,0,0,0.40);
    margin-top: 12px;
    color: #fff !important;
    font-weight: 600 !important;
    border-bottom: none !important;
    letter-spacing: 0.02em;
    text-align: center;
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .cta-nav { display: none; }
    .hamburger { display: flex; }
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu') as HTMLElement;

  hamburger?.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('open');
    hamburger.classList.toggle('open', isOpen);
    hamburger.setAttribute('aria-expanded', String(isOpen));
    menu.setAttribute('aria-hidden', String(!isOpen));
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.remove('open');
      hamburger?.classList.remove('open');
      hamburger?.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
    });
  });
</script>
