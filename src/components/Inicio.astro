  <section class="faq" id="faq">
    <h2>Preguntas<br /><em>Frecuentes</em></h2>

    <div class="questions">
      <div class="faq-item">
        <button class="faq-summary" aria-expanded="false">
          <span>¿La residencia es solo para mujeres?</span>
          <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="faq-content"><p>Sí, es una residencia exclusivamente femenina.</p></div>
      </div>

      <div class="faq-item">
        <button class="faq-summary" aria-expanded="false">
          <span>¿Cuáles son los horarios de entrada y salida?</span>
          <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="faq-content"><p>La residencia abre sus puertas a las 6:00 am y cierra a las 22:00 hrs, de lunes a domingo. Solo se permiten excepciones justificadas por motivos estrictos de estudio.</p></div>
      </div>

      <div class="faq-item">
        <button class="faq-summary" aria-expanded="false">
          <span>¿Cómo puedo solicitar una plaza?</span>
          <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="faq-content"><p>El proceso consta de dos entrevistas con el Equipo Coordinador. <strong>La primera es informativa y requiere la presencia de los padres o un tutor responsable.</strong> La segunda confirma el interés y culmina con la firma del compromiso de convivencia.</p></div>
      </div>

      <div class="faq-item">
        <button class="faq-summary" aria-expanded="false">
          <span>¿Se permite el ingreso de visitas?</span>
          <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="faq-content"><p>Las visitas de familiares o amigos son bienvenidas en la sala de estar hasta las 22:00 hrs. Por seguridad y privacidad de todas, está prohibido el ingreso al segundo y tercer piso donde están las habitaciones.</p></div>
      </div>

      <div class="faq-item">
        <button class="faq-summary" aria-expanded="false">
          <span>¿Debo colaborar con la limpieza?</span>
          <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="faq-content"><p>Sí, la limpieza de la habitación propia es responsabilidad de cada residente. Además, todas las residentes se turnan para limpiar la cocina y el comedor una vez por semana.</p></div>
      </div>

      <div class="faq-item">
        <button class="faq-summary" aria-expanded="false">
          <span>¿Se permite cocinar en la residencia?</span>
          <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="faq-content"><p>Sí, contamos con una cocina equipada y refrigeradoras para uso compartido. Cada residente dispone de casilleros designados para guardar sus alimentos.</p></div>
      </div>
    </div>
  </section>

</main>

<script>
  import Lenis from 'lenis';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const lenis = new Lenis({
    duration: 1.4,
    easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    smoothWheel: true,
  });

  lenis.on('scroll', ScrollTrigger.update);
  gsap.ticker.add((time: number) => { lenis.raf(time * 1000); });
  gsap.ticker.lagSmoothing(0);

  document.querySelectorAll('a[href^="#"]').forEach((a) => {
    a.addEventListener('click', (e) => {
      const href = (a as HTMLAnchorElement).getAttribute('href')!;
      if (href === '#') return;
      e.preventDefault();
      const target = document.querySelector(href);
      if (target) lenis.scrollTo(target as HTMLElement, { offset: -72 });
    });
  });

  gsap.to('.hero-bg', {
    scale: 1.25,
    y: 450,
    scrollTrigger: {
      trigger: '.hero-bg',
      start: 'top 0%',
      end: 'bottom 0%',
      scrub: true,
    },
  });

  gsap.to('.hero-content', {
    opacity: 0,
    y: -60,
    scrollTrigger: {
      trigger: '.hero-banner',
      start: 'center center',
      end: 'bottom top',
      scrub: true,
    },
  });

  gsap.to(['.c2 ', '.i2 '], {
    
    y: -500,
    scrollTrigger: {
      trigger: ".e2",
      start: "top 564px",
      end: "+=500",
      scrub: 0.01
      }

  });
  gsap.to(['.c3 ', '.i3 '], {
    
    y: -1000,
    scrollTrigger: {
      trigger: ".e3",
      start: "top 100%",
      end: "top 0%",
      scrub: 0.01,
      }

  });
  gsap.to(['.c4 ', '.i4 '], {
    
    y: -1500,
    scrollTrigger: {
      trigger: ".e4",
      start: "top 150%",
      end: "top 0%",
      scrub: 0.01,
      }

  });
  gsap.to(['.c5 ', '.i5 '], {
    
    y: -2000,
    scrollTrigger: {
      trigger: ".e5",
      start: "top 200%",
      end: "top 0%",
      scrub: 0.01
      }

  });
  gsap.utils.toArray<HTMLElement>('.benefit-glass').forEach((el, i) => {
    gsap.fromTo(el,
      { opacity: 0, x: -40 },
      {
        opacity: 1,
        x: 0,
        duration: 1,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 75%',
          toggleActions: 'play none none none',
        },
      }
    );
  });

  gsap.utils.toArray<HTMLElement>('.reveal-up').forEach((el) => {
    gsap.fromTo(el,
      { opacity: 0, y: 40 },
      {
        opacity: 1,
        y: 0,
        duration: 0.9,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 80%',
          toggleActions: 'play none none none',
        },
      }
    );
  });

  document.querySelectorAll('.faq-summary').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item') as HTMLElement;
      const content = item.querySelector('.faq-content') as HTMLElement;
      const isOpen = item.classList.contains('open');

      document.querySelectorAll<HTMLElement>('.faq-item').forEach((i) => {
        i.classList.remove('open');
        (i.querySelector('.faq-content') as HTMLElement).style.maxHeight = '0';
        i.querySelector('.faq-summary')!.setAttribute('aria-expanded', 'false');
      });

      if (!isOpen) {
        item.classList.add('open');
        content.style.maxHeight = content.scrollHeight + 'px';
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

<style>
  :root {
    --accent: #000000ff;
    --accent-light: #212325;
    --green: #162D24;
    --green-deep: #0d1f19;
    --snow: #FBFAF8;
    --bone: #E7DECD;
    --glass-bg: rgba(255, 255, 255, 0.04);
    --glass-border: rgba(255, 255, 255, 0.09);
    --muted: #E7DECD;
  }

  main { background-color: var(--green); }

  h1, h2 {
    font-family: 'Montserrat', sans-serif;
    color: var(--snow);
    margin: 0;
    line-height: 1.05;
  }

  h2 em {
    font-family: 'Lora', Georgia, serif;
    font-style: italic;
    font-weight: 900;
    color: var(--muted);
  }

  h1 em{
    font-size: clamp(20px, 6vw, 50px);
    color: var(--muted);
    font-family: 'Inter', sans-serif;
    font-style: normal;
    font-weight: 900;
    
  }
  h1 em::before {
    content: "• ";
  }

  h1 em::after {
    content: " •";
  }

  h3 {
    font-family: 'Montserrat', sans-serif;
    color: var(--snow);
    margin: 0;
    font-weight: 700;
  }

  h4 {
    font-family: 'Hind Madurai', sans-serif;
    color: var(--snow);
    margin: 0;
    font-weight: 600;
  }

  p, a, li {
    font-family: 'Hind Madurai', sans-serif;
  }

  .glass {
    background: var(--glass-bg);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    font-family: 'Hind Madurai', sans-serif;
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.05em;
    padding: 14px 32px;
    background-color: var(--accent);
    color: var(--snow);
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.25s ease, transform 0.2s ease, box-shadow 0.25s ease;
  }

  .btn-primary:hover {
    background-color: rgba(0, 0, 0, 0.5);
    transform: translateY(-2px);
    border: 2px solid var(--accent);
