      <div class="benefit-glass">
        <h3>01 — Todo listo para tu llegada</h3>
        <div class="description">
          <div class="detail">
            <h4>Habitación equipada</h4>
            <p>Cama, escritorio y ropero empotrado.</p>
          </div>
          <div class="detail">
            <h4>Baño compartido</h4>
            <p>Espacios limpios y organizados.</p>
          </div>
          <div class="detail">
